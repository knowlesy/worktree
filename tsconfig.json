{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "moduleResolution": "NodeNext",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "vitest.config.ts",
    "src/test"
  ]
}
